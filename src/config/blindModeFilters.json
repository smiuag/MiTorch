{
  "description": "Blind Mode filters - Comprehensive VipMUD-style configuration",
  "version": "2.0",
  "variables": {
    "playerClass": "desconocida",
    "playerLevel": 0,
    "playerHP": 0,
    "playerMaxHP": 0,
    "playerEnergy": 0,
    "playerMaxEnergy": 0,
    "concentrationActive": false,
    "inCombat": false
  },
  "sounds": {
    "enabled": true,
    "enabledByDefault": false,
    "directory": "assets/sounds",
    "categories": {
      "bloqueos": "bloqueos/",
      "hechizos": "hechizos/",
      "combate": "combate/",
      "eventos": "eventos/"
    }
  },
  "filters": {
    "bloqueos": {
      "enabled": true,
      "class": "all",
      "description": "Bloqueos y restricciones",
      "patterns": [
        {
          "regex": "\\[?El bloqueo '([^']+)' termina\\]?",
          "action": "announce",
          "message": "Bloqueo de {1} terminado",
          "sound": "bloqueos/bloqueo-termina.wav",
          "priority": "normal"
        },
        {
          "regex": "Te estremeces y pierdes la concentración",
          "action": "announce",
          "message": "Pierdes concentración",
          "sound": "combate/pierdes-concentracion.wav",
          "priority": "high",
          "silence": false
        },
        {
          "regex": "Concentración bloqueada",
          "action": "announce",
          "message": "Concentración bloqueada",
          "priority": "high"
        }
      ]
    },
    "hechizos": {
      "enabled": true,
      "class": "magos",
      "description": "Eventos de hechizos arcanos",
      "patterns": [
        {
          "regex": "Preparas los componentes del hechizo",
          "action": "announce",
          "message": "Preparando hechizo",
          "sound": "hechizos/preparas.wav",
          "silence": true
        },
        {
          "regex": "Comienzas a formular el hechizo",
          "action": "announce",
          "message": "Formulando hechizo",
          "sound": "hechizos/formulando.wav",
          "silence": true
        },
        {
          "regex": "resiste los efectos de tu hechizo",
          "action": "announce",
          "message": "Enemigo resiste hechizo",
          "sound": "hechizos/resiste.wav",
          "priority": "normal"
        },
        {
          "regex": "El destino de tu hechizo ha desaparecido",
          "action": "announce",
          "message": "Objetivo fuera de rango",
          "sound": "hechizos/fuera-rango.wav",
          "silence": true
        },
        {
          "regex": "Tus imágenes se desvanecen",
          "action": "announce",
          "message": "Imágenes desvanecidas",
          "sound": "hechizos/imagenes-off.wav",
          "priority": "high"
        },
        {
          "regex": "Tus clones ilusorios se dividen.*imágenes suba a (\\d+)",
          "action": "announce",
          "message": "Imágenes: {1}",
          "sound": "hechizos/imagenes-up.wav"
        },
        {
          "regex": "Tu piel queda cubierta.*capas de piedra",
          "action": "announce",
          "message": "Piel de piedra activada",
          "sound": "hechizos/piel-piedra-on.wav",
          "priority": "normal"
        }
      ]
    },
    "combate_fisico": {
      "enabled": true,
      "class": "guerreros",
      "description": "Combate físico y habilidades",
      "patterns": [
        {
          "regex": "Alcanzas.*a .* con tu maniobra de (.+)!",
          "action": "announce",
          "message": "Golpe: {1}",
          "sound": "combate/impacto.wav",
          "priority": "normal"
        },
        {
          "regex": ".*logra esquivar.*tu maniobra",
          "action": "announce",
          "message": "Esquivado",
          "sound": "combate/esquivado.wav",
          "priority": "normal"
        },
        {
          "regex": ".*logra parar.*tu maniobra",
          "action": "announce",
          "message": "Bloqueado",
          "sound": "combate/bloqueado.wav",
          "priority": "normal"
        },
        {
          "regex": "Tus objetivos ya no están al alcance",
          "action": "announce",
          "message": "Objetivo perdido",
          "sound": "combate/objetivo-perdido.wav",
          "silence": true
        },
        {
          "regex": "Tu maniobra.*se ve interrumpida",
          "action": "announce",
          "message": "Interrupción",
          "sound": "combate/interrumpido.wav",
          "priority": "high"
        },
        {
          "regex": "críticamente",
          "action": "announce",
          "message": "CRÍTICO",
          "sound": "combate/critico.wav",
          "priority": "high"
        }
      ]
    },
    "movimiento": {
      "enabled": true,
      "class": "all",
      "description": "Movimiento y navegación",
      "patterns": [
        {
          "regex": "^(Entras|Arrastras|Subes|Bajas|Cruzas|Saltas).*",
          "action": "announce",
          "message": "Movimiento",
          "announce": true,
          "priority": "normal"
        },
        {
          "regex": "^Caminas hacia.*",
          "action": "announce",
          "message": "Caminando",
          "frequency": "high",
          "silence": true
        }
      ]
    },
    "eventos_criticos": {
      "enabled": true,
      "class": "all",
      "description": "Eventos importantes para la supervivencia",
      "patterns": [
        {
          "regex": "\\[muerte\\]|has muerto|Your death|You have been killed",
          "action": "announce",
          "message": "MUERTE",
          "sound": "eventos/muerte.wav",
          "priority": "high",
          "announce": true
        },
        {
          "regex": "\\[victoria\\]|enemigo ha sido aniquilado|Victory",
          "action": "announce",
          "message": "VICTORIA",
          "sound": "eventos/victoria.wav",
          "priority": "high",
          "announce": true
        },
        {
          "regex": "Ganas ([\\d,]+) puntos de experiencia",
          "action": "announce",
          "message": "XP: +{1}",
          "sound": "eventos/xp.wav",
          "priority": "normal"
        },
        {
          "regex": "ALERTA:|ADVERTENCIA:|WARNING:",
          "action": "announce",
          "message": "Alerta del sistema",
          "priority": "high",
          "announce": true
        }
      ]
    },
    "ambiente": {
      "enabled": true,
      "class": "all",
      "description": "Mensajes repetitivos de ambiente",
      "patterns": [
        {
          "regex": "^\\[.*\\]$",
          "action": "reduce",
          "description": "Reduce ambientación entre corchetes",
          "frequency": "high",
          "silence": false,
          "ratio": 3
        },
        {
          "regex": "^(El viento|La brisa|Escuchas|Ves).*",
          "action": "reduce",
          "description": "Reduce descripciones de ambiente",
          "frequency": "medium",
          "ratio": 2
        }
      ]
    },
    "stats_y_combate": {
      "enabled": true,
      "class": "all",
      "description": "Actualizaciones de stats en combate",
      "patterns": [
        {
          "regex": "Tu salud ha aumentado",
          "action": "announce",
          "message": "Salud restaurada",
          "sound": "eventos/curacion.wav"
        },
        {
          "regex": "Te sientes agotado",
          "action": "announce",
          "message": "Agotado",
          "priority": "high"
        },
        {
          "regex": "enfoque|concentración|alineamiento",
          "action": "announce",
          "message": "Estado modificado",
          "priority": "normal"
        }
      ]
    },
    "prompt_stats": {
      "enabled": true,
      "class": "all",
      "description": "Captura prompt de stats y lo silencia",
      "patterns": [
        {
          "regex": "Pv:(\\d+)[/\\\\](\\d+).*Pe:(\\d+)[/\\\\](\\d+).*Xp:(\\d+).*SL:\\s*\\[?(.+?)\\]?(?=[>]|\\s|$)",
          "action": "capture",
          "captureVars": ["playerHP","playerMaxHP","playerEnergy","playerMaxEnergy","playerXP","roomExits"],
          "silence": true
        },
        {
          "regex": "Pieles:(\\d+)",
          "action": "capture",
          "captureVars": ["playerSkins"],
          "silence": true
        },
        {
          "regex": "Im[aá]genes:(\\d+)",
          "action": "capture",
          "captureVars": ["playerImages"],
          "silence": true
        },
        {
          "regex": "Inercia:(\\d+)",
          "action": "capture",
          "captureVars": ["playerInertia"],
          "silence": true
        },
        {
          "regex": "Astucia:(\\d+)",
          "action": "capture",
          "captureVars": ["playerAstuteness"],
          "silence": true
        }
      ]
    },
    "sala_entidades": {
      "enabled": true,
      "class": "all",
      "description": "Captura enemigos, aliados y combatientes en sala",
      "patterns": [
        {
          "regex": "NM:(.+?)(?=$|>|\\n|\\s{2})",
          "action": "capture",
          "captureVars": ["roomEnemies"],
          "silence": true
        },
        {
          "regex": "LD:(.+?)(?=$|>|\\n|\\s{2})",
          "action": "capture",
          "captureVars": ["roomAllies"],
          "silence": true
        },
        {
          "regex": "PL:(.+?)(?=$|>|\\n|\\s{2})",
          "action": "capture",
          "captureVars": ["roomCombatants"],
          "silence": true
        },
        {
          "regex": "SL:\\s*[\\[\\(]?(.+?)[\\]\\)]?(?=[>]|\\s|$)",
          "action": "capture",
          "captureVars": ["roomExits"],
          "silence": true
        }
      ]
    }
  },
  "classConfigs": {
    "guerreros": {
      "description": "Soldados, Lanceros, Campeones",
      "enabledFilters": ["combate_fisico", "bloqueos", "movimiento", "eventos_criticos", "stats_y_combate", "prompt_stats", "sala_entidades"],
      "disabledFilters": ["hechizos"]
    },
    "magos": {
      "description": "Magos, Hechiceros, Brujos",
      "enabledFilters": ["hechizos", "bloqueos", "movimiento", "eventos_criticos", "stats_y_combate", "prompt_stats", "sala_entidades"],
      "disabledFilters": ["combate_fisico"]
    },
    "hibridos": {
      "description": "Paladines, Rangers, Druidas",
      "enabledFilters": ["combate_fisico", "hechizos", "bloqueos", "movimiento", "eventos_criticos", "stats_y_combate", "prompt_stats", "sala_entidades"],
      "disabledFilters": []
    },
    "generica": {
      "description": "Configuración por defecto",
      "enabledFilters": ["bloqueos", "movimiento", "eventos_criticos", "stats_y_combate", "ambiente", "prompt_stats", "sala_entidades"],
      "disabledFilters": []
    }
  }
}
